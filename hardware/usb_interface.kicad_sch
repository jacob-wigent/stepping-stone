	)
	(text "R_{ILIM} should be a 1% resistor\nbetween 15k and 232k.\n\nI_{MAX} = 22980V / (R_{ILIM}^{0.94})\nI_{MAX} = 22980V / (59k^{0.94})\n= 500mA"
		(exclude_from_sim no)
		(at 189.23 101.6 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "41fe1b53-c751-4e85-9f13-80210642a7fa")
	)
	(text "Soft-start / Current Limiting"
		(exclude_from_sim no)
		(at 171.45 71.12 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.254)
				(bold yes)
				(color 132 0 0 1)
			)
		)
		(uuid "423b8b58-8edc-495e-8891-c38e53601f24")
	)
	(text "TVS & Filtering"
		(exclude_from_sim no)
		(at 115.57 73.66 0)
		(effects
			(font
				(size 2.032 2.032)
				(thickness 0.254)
				(bold yes)
				(color 132 0 0 1)
			)
		)
		(uuid "4fda87e2-1581-4294-a96f-274e90a7ae31")
	)
	(text "Asymmetric voltage divider\nto drive ~{EN} below 0.66V\nthreshold when manually\nenabled."
		(exclude_from_sim no)
		(at 146.685 109.22 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "78e4a638-5a67-4618-89d7-c38ab1deac40")
	)
	(text "Place filtering and IC close."
		(exclude_from_sim no)
		(at 116.205 95.25 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "99d88475-518f-4931-a988-0c65b77a014b")
	)
	(text "USB-C Connector"
		(exclude_from_sim no)
		(at 76.2 71.12 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.254)
				(bold yes)
				(color 132 0 0 1)
			)
		)
		(uuid "b8f84af7-517f-4258-b557-378ffa6815ad")
	)
	(text "USB-C 2.0 connection is protected against ESD through\nTVS diode array, and filtered using a ferrite bead and\nlow-ESR ceramic capacitors. A dedicated load switch IC\nwith built-in soft-start and programmable current\nlimiting ensures 500mA USB spec, and limits inrush.\n\nVBUSF is exposed before the load switch, allowing an\nMCU to remain operational during power faults.\nThe ~{FAULT} output of the load switch can be monitored,\nenabling firmware-level fault detection and response."
		(exclude_from_sim no)
		(at 13.97 27.94 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.1588)
			)
			(justify left)
		)
		(uuid "fa6aad33-d7d9-45ba-8438-7d8db0f34479")
	)
